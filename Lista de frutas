import 'package:flutter/material.dart';

void main() {
  runApp(const ListaFrutas());
}

class ListaFrutas extends StatelessWidget {
  const ListaFrutas({super.key});

  //lista de frutas
  final List<String> entries = const <String>[
    'manzana',
    'pera',
    'uva',
    'sandia',
  ];
  // numero de variable de color
  final List<int> colorCodes = const <int>[600, 500, 300, 100];

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'Lista de Frutas', // title
      debugShowCheckedModeBanner: false,
      home: Scaffold(
        appBar: AppBar(title: const Text('Lista de Frutas')),
        body: ListView.separated(
          padding: const EdgeInsets.all(8),
          itemCount: entries.length,
          itemBuilder: (BuildContext context, int index) {
            return Container(
              height: 50,
              color: Colors.blue[colorCodes[index]],
              child: Center(
                child: Text(
                  entries[index].toUpperCase(),
                  style: const TextStyle(
                    color: Colors.white,
                    fontWeight: FontWeight.bold,
                  ),
                ),
              ),
            );
          },
          separatorBuilder: (BuildContext context, int index) =>
              const Divider(),
        ),
      ),
    );
  }
}
